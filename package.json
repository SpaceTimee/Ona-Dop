{
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:e2e": "chcp 65001 && start-server-and-test preview http://localhost:4173 \"cypress run --e2e\"",
    "test:e2e:dev": "chcp 65001 && start-server-and-test \"vite dev --port 4173\" http://localhost:4173 \"cypress open --e2e\"",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --fix",
    "format": "prettier --write ."
  },
  "packageManager": "pnpm@11.3.0",
  "dependencies": {
    "@vercel/speed-insights": "^2.0.0",
    "axios": "^1.18.1",
    "vite-plugin-vuetify": "^2.1.3",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0",
    "vuetify": "^4.1.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "cypress": "^15.18.1",
    "eslint": "^10.7.0",
    "eslint-plugin-cypress": "^6.4.2",
    "eslint-plugin-vue": "^10.9.2",
    "jsdom": "^29.1.1",
    "less": "^4.6.7",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.5",
    "start-server-and-test": "^3.0.11",
    "typescript": "~6.0.3",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-sitemap": "^0.8.2",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "type": "module"
}
